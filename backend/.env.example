SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key
GROQ_API_KEY=your_groq_api_key
# Optional — if Groq deprecates a model ID, set a current one from:
# https://console.groq.com/docs/models
# GROQ_MODEL=llama-3.3-70b-versatile
# Optional — uncomment in ai_service.py to use Claude instead of Groq
# ANTHROPIC_API_KEY=your_anthropic_api_key
# Seconds to cache Yahoo last prices per ticker (portfolio loads). Default 90; min 15.
# QUOTE_CACHE_TTL_SECONDS=90
# Pause between Yahoo quote calls when loading portfolio (reduces 429 rate limits). Default 0.25
# QUOTE_FETCH_STAGGER_SEC=0.25
